# ── ResuLens — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary: Get a FREE key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Fallback: Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Optional: If not set, the app falls back to local JSON file storage
MONGODB_URI=mongodb://localhost:27017/resulens

# ── Application URL ───────────────────────────────────────────────────────────
# Used for CORS referer headers. Set to your production domain in deployment.
APP_URL=http://localhost:5173

# ── CORS (Production only) ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── JWT Session ───────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d
SESSION_LIFETIME=3600000

# ── Security & Performance Configs ─────────────────────────────────────────────
UPLOAD_LIMIT_MB=5
API_LIMITS_GLOBAL=100
API_LIMITS_AUTH=10
SECURITY_THRESHOLDS=5

# ── Email Settings (For Password Recovery) ────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
