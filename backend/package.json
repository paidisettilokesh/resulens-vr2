{
    "name": "resulens-backend",
    "version": "2.0.0",
    "description": "ResuLens API — AI-powered resume intelligence backend (Node.js + Express + MongoDB)",
    "type": "module",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch-path=./routes --watch-path=./utils --watch-path=./models --watch-path=./config --watch-path=./server.js server.js",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "db:backup": "node scripts/dbBackup.js"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "axios": "^1.18.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.5.2",
        "form-data": "^4.0.6",
        "google-auth-library": "^10.6.2",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "mammoth": "^1.6.0",
        "mongoose": "^9.2.1",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^9.0.1",
        "pdf-parse": "^1.1.1",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "jest": "^30.4.2"
    }
}
